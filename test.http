### Variables
@host = http://localhost:3000

### 1. Check server is alive
GET {{host}}/

### 2. Create a high priority task
POST {{host}}/tasks
Content-Type: application/json

{
  "title": "Build the API",
  "description": "Finish the task manager project",
  "priority": "high"
}

> {%
    client.global.set("createdId", response.body.data.id);
%}

### 3. Create a medium priority task
POST {{host}}/tasks
Content-Type: application/json

{
  "title": "Write unit tests",
  "description": "Test all endpoints thoroughly",
  "priority": "medium"
}

> {%
    client.global.set("secondId", response.body.data.id);
%}

### 4. Create a low priority task
POST {{host}}/tasks
Content-Type: application/json

{
  "title": "Update documentation",
  "description": "Keep the README up to date",
  "priority": "low"
}

> {%
    client.global.set("thirdId", response.body.data.id);
%}

### 5. [FAIL CASE] Missing title (expect 400)
POST {{host}}/tasks
Content-Type: application/json

{
  "description": "This should fail validation"
}

### 6. [FAIL CASE] Missing description (expect 400)
POST {{host}}/tasks
Content-Type: application/json

{
  "title": "This should also fail"
}

### 7. [FAIL CASE] Invalid priority (expect 400)
POST {{host}}/tasks
Content-Type: application/json

{
  "title": "Bad priority task",
  "description": "This should fail too",
  "priority": "urgent"
}

### 8. Get all tasks
GET {{host}}/tasks

### 9. Filter by high priority
GET {{host}}/tasks?priority=high

### 10. Filter by low priority
GET {{host}}/tasks?priority=low

### 11. Filter completed tasks
GET {{host}}/tasks?completed=true

### 12. Filter pending tasks
GET {{host}}/tasks?completed=false

### 13. Get the first created task
GET {{host}}/tasks/{{createdId}}

### 14. [FAIL CASE] Get non-existent task (expect 404)
GET {{host}}/tasks/99999

### 15. [FAIL CASE] Invalid id format (expect 400)
GET {{host}}/tasks/not-a-number

### 16. Update task title only
PUT {{host}}/tasks/{{createdId}}
Content-Type: application/json

{
  "title": "Build the API (updated)"
}

### 17. Update task priority
PUT {{host}}/tasks/{{createdId}}
Content-Type: application/json

{
  "priority": "low"
}

### 18. [FAIL CASE] Update with invalid priority (expect 400)
PUT {{host}}/tasks/{{createdId}}
Content-Type: application/json

{
  "priority": "urgent"
}

### 19. [FAIL CASE] Update with empty body (expect 400)
PUT {{host}}/tasks/{{createdId}}
Content-Type: application/json

{}

### 20. Mark task as complete
PATCH {{host}}/tasks/{{createdId}}/complete

### 21. Filter completed tasks (should now show the completed one)
GET {{host}}/tasks?completed=true

### 22. Get stats
GET {{host}}/tasks/stats

### 23. Upload PDF attachment
# Place a file named sample.pdf next to this test.http file before running.
POST {{host}}/tasks/{{createdId}}/attachment
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="sample.pdf"
Content-Type: application/pdf

< ./sample.pdf
--WebAppBoundary--

### 24. [FAIL CASE] Upload non-PDF file (expect 400)
# Place any text file named sample.txt next to this test.http file.
POST {{host}}/tasks/{{createdId}}/attachment
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="sample.txt"
Content-Type: text/plain

< ./sample.txt
--WebAppBoundary--

### 25. [FAIL CASE] Upload with no file field (expect 400)
POST {{host}}/tasks/{{createdId}}/attachment
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary--

### 26. Get task to confirm attachment is saved
GET {{host}}/tasks/{{createdId}}

### 27. Delete a task
DELETE {{host}}/tasks/{{createdId}}

### 28. [FAIL CASE] Get deleted task (expect 404)
GET {{host}}/tasks/{{createdId}}

### 29. Get final stats
GET {{host}}/tasks/stats